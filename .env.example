# Firebase Web (client) - safe to expose
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server) - keep secret. Use a service account JSON.
# Paste the entire service account JSON on one line (escape newlines as \n in private_key).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Session cookie secret (used to sign Firebase ID tokens into a session cookie)
SESSION_COOKIE_NAME=__sentinel_session

# OpenAI (Phase 3 — AI Copilot). If unset, copilot/explain/reports run in offline stub mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
